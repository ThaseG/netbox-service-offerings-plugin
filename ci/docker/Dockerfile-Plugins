# Builds the base NetBox image with third-party plugins baked in, plus this
# repo's own first-party "service_specification" plugin. Third-party plugin pattern follows:
# https://github.com/netbox-community/netbox-docker/wiki/Using-Netbox-Plugins
#
# Build context is the repo root (see docker-compose.yml's build.context),
# so paths below are relative to the repo root, not this file's directory.
ARG NETBOX_VERSION
FROM netboxcommunity/netbox:${NETBOX_VERSION}

COPY ci/docker/plugin_requirements.txt /opt/netbox/
RUN /usr/local/bin/uv pip install -r /opt/netbox/plugin_requirements.txt

# First-party plugin developed in this repo. Installed as a regular
# (non-editable) package, same as the third-party plugins above — the
# image is rebuilt from source on every deploy, so there's no need for an
# editable install.
COPY pyproject.toml /opt/netbox-plugin-src/pyproject.toml
COPY service_specification /opt/netbox-plugin-src/service_specification
RUN /usr/local/bin/uv pip install /opt/netbox-plugin-src

COPY ci/docker/configuration/plugins.py /etc/netbox/config/plugins.py

# Bake static files (incl. plugin assets) into the image at build time
# rather than regenerating them on every container start. Dummy
# DEBUG/SECRET_KEY: collectstatic doesn't touch the database or need real
# secrets, it only needs Django to boot far enough to run.
RUN DEBUG="true" SECRET_KEY="dummydummydummydummydummydummydummydummydummydummy" \
    /opt/netbox/venv/bin/python /opt/netbox/netbox/manage.py collectstatic --no-input
