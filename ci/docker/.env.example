# Template for ci/docker/.env — the file the deploy pipeline generates at
# runtime from GitHub Actions secrets/variables. It is written fresh on
# every deploy and removed again afterwards; it is never committed
# (see .gitignore). Copy this file to ci/docker/.env and fill in real values
# only if you want to run `docker compose` by hand on the server, e.g. for
# local debugging.
#
# See README.md for where each of these is configured in GitHub
# (repository Secrets vs Variables) and how to generate safe values.

# --- non-secret configuration (GitHub Actions "Variables") -----------------
NETBOX_DOMAIN=netbox.example.com
ACME_EMAIL=you@example.com

# --- secrets (GitHub Actions "Secrets") -------------------------------------
NETBOX_SECRET_KEY=
POSTGRES_PASSWORD=
REDIS_PASSWORD=
REDIS_CACHE_PASSWORD=
NETBOX_SUPERUSER_PASSWORD=
# v2 API token for the bootstrap superuser — both of the next two are
# required together, or netbox-docker's super_user.py silently skips
# creating any token at all. NETBOX_SUPERUSER_API_KEY must be exactly 12
# alphanumeric characters (NetBox's TOKEN_KEY_LENGTH); generate e.g. with
# `tr -dc 'A-Za-z0-9' < /dev/urandom | head -c 12`.
NETBOX_SUPERUSER_API_TOKEN=
NETBOX_SUPERUSER_API_KEY=
# Cryptographic pepper for hashing v2 API tokens — must be a plain string
# of at least 50 characters (NetBox rejects anything shorter at boot).
# `openssl rand -base64 40` comfortably clears this (56 chars).
API_TOKEN_PEPPER_1=

# NETBOX_VERSION is not set here — it comes from versions.sh (repo root),
# sourced by the pipeline (or by hand:
# `source ../../versions.sh && export NETBOX_VERSION`).
